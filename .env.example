# Copy this file to .env and fill in your real values.

# SQL Server connection
SQL_SERVER=localhost\SQLEXPRESS
SQL_DATABASE=AKPOS
SQL_USER=sa
SQL_PASSWORD=your_password_here
# Set to true if your SQL Server uses TLS (most local installs: false)
SQL_ENCRYPT=false
# Set to true to trust self-signed certs (typical for local SQL Server)
SQL_TRUST_SERVER_CERT=true

# The shared password / API key you'll enter on your phone.
# Pick something long and random.
API_KEY=change-me-to-a-long-random-string

# Port the web server listens on
PORT=3000
